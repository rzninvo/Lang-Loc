# LangLoc annotation-website environment variables.
#
# Copy this file to .env (which is gitignored) and fill in your own
# secrets. tools/annotation_website/launch.sh sources it on startup.

# Signing key for the per-browser annotator cookie. Anything that
# changes here invalidates every existing session. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
LANGLOC_COOKIE_SECRET=replace-me-with-a-random-string

# Admin bearer token for /admin/coverage. Anyone with this can see
# raw annotator UUIDs and per-frame submission counts.
LANGLOC_ADMIN_TOKEN=replace-me-with-a-random-string

# Bind address and port (defaults are fine for local dev).
LANGLOC_HOST=0.0.0.0
LANGLOC_PORT=8000

# Per-frame redundancy cap for descriptions. The localization side
# uses a fixed cap of 1 (the per-frame global exclusion in
# server/localization.py). Set this to 1 to disable description
# redundancy entirely, 2/3 to ask multiple humans for each frame.
LANGLOC_REDUNDANCY=1
