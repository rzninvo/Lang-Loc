# LangLoc — gitignore.
#
# Anything that's user-specific, generated, or too big to ship lives here.
# Stay paranoid about secrets and dataset roots: those should never end
# up tracked even if a user types `git add .`

# ── Datasets and large output trees (must be fetched separately) ────────
/data
/eval
/outputs
/results
/teaser_output
/figures
/manifests/*.txt.bak

# ── Working notes (gitignored on purpose; see CLAUDE.md §9) ─────────────
/docs
/logs
CLAUDE.md
Lang_Loc_ECCV26.pdf
REPO_REPORT.md
REPO_SUMMARY.md
REPO_SUMMARY.pdf

# ── Build / install artifacts ───────────────────────────────────────────
__pycache__/
*.egg-info/
*.egg
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# ── Editor / OS metadata ────────────────────────────────────────────────
.vscode
.idea
.DS_Store
Thumbs.db

# ── Local IDE/agent caches ──────────────────────────────────────────────
.claude

# ── Local secrets ───────────────────────────────────────────────────────
# .env files contain API keys and session secrets. NEVER commit.
# Keep .env.example tracked as a template for new users.
.env
!.env.example
tools/annotation_website/.env
!tools/annotation_website/.env.example

# ── Annotation website runtime data (PII + ephemeral) ───────────────────
tools/annotation_website/data/annotations.db
tools/annotation_website/data/annotations.db-shm
tools/annotation_website/data/annotations.db-wal
tools/annotation_website/data/annotations.jsonl
tools/annotation_website/data/backups/
tools/annotation_website/logs/
# Keyframe images are derived from data/scans; users regenerate via
# tools/annotation_website/scripts/prepare_keyframes.py
tools/annotation_website/static/keyframes/

# ── External colleague archives + vendored repos ────────────────────────
VLSG.ipynb
VLSG_Files-*.zip
/VLSG_TEXT_v2
/VLSG-TEXT
/whereami-text2sgm
/Abu

# ── PyTorch3D / open3d/torch wheels (built locally, large) ──────────────
*.whl
