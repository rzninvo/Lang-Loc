# LangLoc environment variables (root).
#
# Copy this file to .env (which is gitignored) and fill in your own
# values. The .env file is loaded by tools that need API access at
# runtime; no production code in the langloc package reads it.
#
# Required by:
#   - tools/baselines/gpt_vlm/run_descriptions.py
#   - tools/baselines/human/extract_descriptions.py (for the parser step)
#   - langloc/dataset/annotation/parse_descriptions.py
#
# OpenAI vision / GPT-4o-mini account. See
#   https://platform.openai.com/api-keys
# for how to issue a key. The repo's vision-baseline experiment cost
# ~$31 on 1915 ScanNet+3RScan calls; the parser step (gpt-4o-mini) is
# ~$0.001 per frame. Set a cost cap via LANGLOC_GPT_MAX_USD if you
# want to bound any individual run.
OPENAI_API_KEY=sk-proj-REPLACE-ME

# Optional cost cap for tools/baselines/gpt_vlm/run_descriptions.py
# (the script's --max-cost-usd flag overrides this).
LANGLOC_GPT_MAX_USD=20
